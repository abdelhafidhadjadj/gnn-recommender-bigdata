# ── GNN Recommender — Docker environment variables ────────────────────────────
# Copy to docker/.env and edit before launching:
#   cp docker/.env.example docker/.env

# ── Training ──────────────────────────────────────────────────────────────────
TRAINING_MODE=scratch        # scratch | incremental
MODEL_TYPE=sage              # sage | gat | lightgcn

# ── Workers logiques (simulation distribution sur 1 GPU) ──────────────────────
WORLD_SIZE=1                 # 1=standard | 2=bigdata léger | 4=bigdata distribué
MASTER_PORT=29500

# ── Données ───────────────────────────────────────────────────────────────────
DATA_DIR=data/raw/50k        # 1k | 5k | 10k | 50k | 100k | full
CKPT_DIR=checkpoints

# ── Reproducibilité ───────────────────────────────────────────────────────────
SEED=42
