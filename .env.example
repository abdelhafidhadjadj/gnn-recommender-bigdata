# ── GNN Recommender — Docker environment variables ────────────────────────────
# Copy to docker/.env and edit before launching:
#   cp docker/.env.example docker/.env

# ── Training ──────────────────────────────────────────────────────────────────
TRAINING_MODE=scratch        # scratch | incremental (Phase 6)
MODEL_TYPE=sage              # sage | gat | lightgcn

# ── Distributed ───────────────────────────────────────────────────────────────
WORLD_SIZE=4                 # number of GPUs (= nproc_per_node)
MASTER_PORT=29500            # torchrun rendezvous port (change if busy)

# ── Reproducibility ───────────────────────────────────────────────────────────
SEED=42

# ── Data / checkpoints ────────────────────────────────────────────────────────
# These are CONTAINER paths (mapped from host via volumes in docker-compose.yml)
# DATA_DIR=/workspace/data/raw        # passed as --data-dir
# CKPT_DIR=/workspace/checkpoints     # passed as --ckpt-dir

# ── Optional overrides ────────────────────────────────────────────────────────
# EMB_DIM=128                         # override embedding dimension
# NUM_EPOCHS=200
# LR=0.005
